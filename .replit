modules = ["nodejs-20", "web"]

[deployment]
router = "application"
deploymentTarget = "autoscale"
run = ["bash", "-c", "cd artifacts/api-server && node --enable-source-maps --env-file=.env ./dist/index.mjs"]
build = ["bash", "-c", "pnpm install && pnpm --filter @workspace/yunora-admin run build && pnpm --filter @workspace/api-server run build"]

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]

[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"
packages = ["gemini-cli", "firebase-tools"]

[[ports]]
localPort = 3000
externalPort = 3001

[[ports]]
localPort = 8080
externalPort = 80

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 25736
externalPort = 3000

[userenv]

[userenv.shared]
