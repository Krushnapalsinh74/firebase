{
  "hosting": {
    "public": "artifacts/yunora-admin/dist/public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/api/**",
        "function": "api"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "functions": {
    "source": "artifacts/api-server/dist",
    "runtime": "nodejs22",
    "predeploy": ["npm install --prefix artifacts/api-server/dist"]
  }
}
