{
  "hosting": {
    "public": "artifacts/yunora-admin/dist/public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/api/**",
        "function": "api"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "functions": {
    "source": "artifacts/api-server/dist",
    "runtime": "nodejs22",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/*.map"
    ],
    "predeploy": [
      "pnpm --filter @workspace/api-server run build",
      "npm install --prefix artifacts/api-server/dist"
    ]
  }
}
